import random




def mediaaleatoria(numeros,n):
    tamMuestra=n//2
    
    suma=0
    for i in range(tamMuestra):
        aleatorio=random.choice(numeros)
        suma+=aleatorio

    media=0
    media=suma/tamMuestra
    print("La media con muestreo aleatorio es ",media)




