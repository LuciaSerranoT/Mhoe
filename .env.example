# Variables de entorno para el Portfolio React
# Copia este archivo como .env.local y configura tus valores

# Configuración de desarrollo
VITE_APP_TITLE="Mi Portfolio - Ingeniera Informática"
VITE_APP_DESCRIPTION="Portfolio profesional especializado en desarrollo de software"

# Configuración de contacto (opcional)
VITE_EMAIL="tu-email@gmail.com"
VITE_LINKEDIN="https://linkedin.com/in/tu-perfil"
VITE_GITHUB="https://github.com/tu-usuario"

# Configuración de analytics (opcional)
VITE_GA_TRACKING_ID="GA-XXXXXXXXXX"

# Configuración de API (para futuras integraciones)
VITE_API_BASE_URL="https://api.ejemplo.com"